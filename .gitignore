# Ignore bundler config
/.bundle

# Ignore environment variables
.env*
!.env.example

# Ignore logs and temp files
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pid files
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (Active Storage)
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore uploaded assets
/public/assets

# Ignore node modules (if using JS bundlers)
/node_modules

# Ignore build assets
/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore database config (IMPORTANT)
/config/database.yml

# Ignore master key (IMPORTANT)
/config/master.key

# Ignore credentials key backups
/config/credentials/*.key

# Ignore SQLite databases
/db/*.sqlite3
/db/*.sqlite3-journal

# Ignore system files
.DS_Store
Thumbs.db

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo

# Ignore coverage reports
/coverage

# Ignore yarn/npm logs
yarn-debug.log*
yarn-error.log*
npm-debug.log*

# Ignore byebug history
.byebug_history

# Ignore Ruby version managers
.ruby-version
.ruby-gemset

# Ignore test temp files
/spec/tmp
/test/tmp

# Ignore cache
/tmp/cache