<div class="navbar">
  <div class="logo">OdinBook</div>

  <div class="nav-links">
    <% if user_signed_in? %>
      <span class="user-email"><%= current_user.email %></span>
      <%= link_to "Feed", posts_path, class: "nav-btn" %>
      <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "nav-btn logout" %>
    <% else %>
      <%= link_to "Login", new_user_session_path, class: "nav-btn" %>
      <%= link_to "Sign Up", new_user_registration_path, class: "nav-btn signup" %>
    <% end %>
  </div>
</div>
<div class="main1">
<div class="main-container">

  <!-- LEFT -->
  <div class="left-section">
    <h1>OdinBook</h1>
    <p>Share moments. Connect instantly. Explore freely.</p>
  </div>

  <!-- RIGHT -->
  <div class="right-section">
    <div class="card">

      <% if user_signed_in? %>
        <h2>Welcome Back 👋</h2>
        <p><%= current_user.email %></p>
        <%= link_to "Go to Feed", posts_path, class: "btn primary" %>
      <% else %>
        <h2>Join OdinBook</h2>
        <%= link_to "Log In", new_user_session_path, class: "btn primary" %>
        <%= link_to "Create Account", new_user_registration_path, class: "btn secondary" %>
      <% end %>

    </div>
  </div>

</div>
</div>